# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=internship_tracker

# JWT  (keep secrets long & private — min 32 chars each)
JWT_SECRET=change_this_access_secret_min_32_chars
REFRESH_TOKEN_SECRET=change_this_refresh_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Collection for storing refresh tokens (auto-created if not present)
REFRESH_TOKEN_COLLECTION=refresh_tokens

# Field in your user doc that stores the bcrypt password hash
PASSWORD_HASH_FIELD=passwordHash

# CORS  (React dev server)
CLIENT_ORIGIN=http://localhost:5173

# Collection names — change these if your DB uses different names
INTERN_COLLECTION=interns
USER_COLLECTION=users
ASSIGNMENT_COLLECTION=assignments
STANDUP_COLLECTION=standups
MILESTONE_COLLECTION=milestones
REVIEW_COLLECTION=reviews

# SSO: field on the JWT payload that holds the employee's unique ID
# Common values: employeeId | eid | empCode | sub
SSO_ID_FIELD=employeeId
