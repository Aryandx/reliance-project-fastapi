# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=internship_tracker

# JWT  (keep secret, min 32 chars)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS  (React dev server)
CLIENT_ORIGIN=http://localhost:5173

# Collection names — change these if your DB uses different names
INTERN_COLLECTION=interns
USER_COLLECTION=users
ASSIGNMENT_COLLECTION=assignments
STANDUP_COLLECTION=standups
MILESTONE_COLLECTION=milestones
REVIEW_COLLECTION=reviews

# SSO: field on the JWT payload that holds the employee's unique ID
# Common values: employeeId | eid | empCode | sub
SSO_ID_FIELD=employeeId
